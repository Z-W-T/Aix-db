# LangFuse 配置 默认关闭 (可选)
LANGFUSE_TRACING_ENABLED="True"
LANGFUSE_SECRET_KEY="sk-lf-3b020a80-91f7-4922-952f-47b89379639e"
LANGFUSE_PUBLIC_KEY="pk-lf-e3b8e83b-0354-46b8-a8ce-065d23dc8d84"
